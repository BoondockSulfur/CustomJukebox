# Normalize line endings for all text files
* text=auto

# Java source files - LF
*.java text eol=lf
*.kt text eol=lf
*.kts text eol=lf

# Config/resource files - LF
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.properties text eol=lf

# Shell scripts - LF
gradlew text eol=lf
*.sh text eol=lf

# Windows scripts - CRLF
*.bat text eol=crlf

# Markdown - LF
*.md text eol=lf

# Binary files
*.jar binary
*.png binary
*.ogg binary
*.zip binary
